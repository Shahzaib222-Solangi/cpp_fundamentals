#include <iostream>
using namespace std;

int main() {
    int num, sum = 0;

    cout << "Enter the number: ";
    cin >> num;

    while (num >= 0) {
        if (num > 30) {
            cout << "The entered number is greater than 30; it won't be calculated." << endl;
        } else {
            sum = sum + num;
        }

        cout << "Enter the number: ";
        cin >> num;
    }

    cout << "Total Sum: " << sum << endl;

    return 0;
}
